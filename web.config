<?xml version="1.0" encoding="utf-8"?>
<!--
  Azure App Service (Windows): habilita WebSockets en IIS/ARR para el radar AIS.
  En Linux no se usa este archivo; el proceso Node escucha directamente en process.env.PORT.
-->
<configuration>
  <system.webServer>
    <webSocket enabled="true" />
    <handlers>
      <add name="iisnode" path="server/index.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <rule name="NodeApp">
          <match url="/*" />
          <action type="Rewrite" url="server/index.js" />
        </rule>
      </rules>
    </rewrite>
    <iisnode watchedFiles="web.config;server\.env" nodeProcessCommandLine="node" />
  </system.webServer>
</configuration>
